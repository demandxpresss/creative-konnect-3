# ── Sanity CMS ────────────────────────────────────────────────────
# Get these from https://sanity.io/manage → your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id-here
NEXT_PUBLIC_SANITY_DATASET=production

# ── Resend (Email) ─────────────────────────────────────────────────
# Get from https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Notion (Lead Database) ─────────────────────────────────────────
# Get from https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The ID of your Notion database (from the database URL)
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Sheets (Lead Backup) ────────────────────────────────────
# Apps Script web app URL (POST JSON) to append leads into a sheet
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx/exec

# ── Analytics ─────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ── Google Search Console ─────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cloudinary (Media) ────────────────────────────────────────────
# Get from https://cloudinary.com → Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# ── Site ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.creativekonnect.com
